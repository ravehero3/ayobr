# Database & auth (required)
DATABASE_URL=
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public app URL (required in production for OAuth + checkout redirect)
APP_URL=https://typebeatz.com
FRONTEND_URL=https://typebeatz.com

# Lemon Squeezy (international payments)
# API key: Settings → API. Store ID: Settings → Stores.
# Variant IDs: Products → [plan] → Variants → copy the VARIANT id (numeric, e.g. 123456).
# Do NOT use Paddle pri_* IDs or product IDs — only variant IDs from the same store as LEMONSQUEEZY_STORE_ID.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PRO_YEARLY_VARIANT_ID=
LEMONSQUEEZY_UNLIMITED_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_UNLIMITED_YEARLY_VARIANT_ID=
